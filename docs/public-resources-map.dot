digraph G {
    rankdir=LR;
    node [shape=box, style="filled,rounded", color="#1a73e8", fontcolor=white, fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize=10];

    // Nodes
    sre_extension [label="SRE Extension\n(gemini-cli-extensions/sre)", fillcolor="#1a73e8"];
    about_sre_extension [label="Reference PostMortems\n(palladius/about-sre-extension)", fillcolor="#34a853"];
    testing_suite [label="SRE Testing Suite\n(palladius/sre-testing-suite)", fillcolor="#f9ab00", fontcolor=black];
    gke_codelab [label="GKE Breakage Codelab\n(Google Codelabs)", fillcolor="#ea4335"];
    sre_classroom [label="Google SRE Classroom\n(Generic Mitigations)", fillcolor="#8ab4f8", fontcolor=black];
    sre_blog [label="Google Cloud Blog\n(How SREs use Gemini CLI)", fillcolor="#8ab4f8", fontcolor=black];
    survey [label="SRE Extension Survey\n(Google Forms)", fillcolor="#9c27b0"];

    // Relationships (Verbs)
    sre_extension -> about_sre_extension [label="references"];
    sre_extension -> testing_suite [label="references"];
    sre_extension -> survey [label="collects feedback via"];
    sre_extension -> sre_classroom [label="references"];
    sre_extension -> sre_blog [label="references"];

    testing_suite -> gke_codelab [label="has related"];
    gke_codelab -> testing_suite [label="references"];
    gke_codelab -> sre_extension [label="demonstrates"];

    sre_classroom -> sre_extension [label="philosophical basis for"];
    sre_blog -> sre_extension [label="showcases"];
}
